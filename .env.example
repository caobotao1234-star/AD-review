# 火山方舟 API 配置
ARK_API_KEY=your-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型名称（直接填模型名，也支持填 ep-xxxxx 格式的接入点ID）
ARK_REASONING_MODEL=doubao-1.5-pro-32k
ARK_VISION_MODEL=doubao-1.5-vision-pro-32k
# Embedding 使用 ChromaDB 内置模型，无需配置

# 置信度阈值（低于此值进入人工复核）
CONFIDENCE_THRESHOLD=0.7

# 批量处理上限
MAX_BATCH_SIZE=10
