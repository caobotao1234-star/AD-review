# 火山方舟 API 配置
ARK_API_KEY=your-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型 Endpoint ID（在火山方舟控制台创建推理接入点后获取）
ARK_REASONING_MODEL=your-doubao-1.5-pro-32k-endpoint-id
ARK_VISION_MODEL=your-doubao-1.5-vision-pro-32k-endpoint-id
ARK_EMBEDDING_MODEL=your-doubao-embedding-endpoint-id

# 置信度阈值（低于此值进入人工复核）
CONFIDENCE_THRESHOLD=0.7

# 批量处理上限
MAX_BATCH_SIZE=10
